# flowlyst-website environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# See docs/development.md for the full local setup walkthrough.

# --- Required to run the app locally ---

# Postgres connection string.
# Local dev (matches docker-compose.yml): postgres://flowlyst:flowlyst@localhost:5432/flowlyst
# In CI this points at the Postgres service container; in production it is the Neon
# connection string (Tural provisions Neon — issue #5 — and sets this in Vercel).
DATABASE_URL=postgres://flowlyst:flowlyst@localhost:5432/flowlyst

# Payload signing secret (encrypts auth tokens, etc.). Generate a unique random
# value per environment: `openssl rand -hex 32`. Never commit a real value.
PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET_HERE

# --- CMS (issue #4) — all optional locally; set in staging/prod. See docs/cms.md ---
# BLOB_READ_WRITE_TOKEN=     # Vercel Blob media storage. Set by Vercel Blob; absent -> local filesystem.
# CRON_SECRET=               # Secures GET /api/payload-jobs/run for scheduled publishing (Vercel Cron).
# PREVIEW_SECRET=            # Draft-preview secret. Optional; falls back to PAYLOAD_SECRET.

# --- Added by later issues (leave unset for now) ---
# RESEND_API_KEY=            # transactional email (forms) — decided in issue #1, wired later
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # reCAPTCHA on demo/contact forms — forms issue
# RECAPTCHA_SECRET_KEY=             # reCAPTCHA server-side verification — forms issue
